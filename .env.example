# ─── Azure OpenAI ────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# These values are used by the postgres Docker container AND as defaults
# for building DATABASE_URL when it is not set explicitly.
POSTGRES_USER=conference
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=conference_db

# Optional: DATABASE_URL overrides the auto-built connection string.
# If omitted, it is constructed from POSTGRES_USER, POSTGRES_PASSWORD,
# POSTGRES_DB, POSTGRES_HOST (default: postgres), and POSTGRES_PORT (default: 5432).
DATABASE_URL=postgresql://conference:change-me-in-production@postgres:5432/conference_db

# ─── Internal Service URLs ────────────────────────────────────────────────────
# These default to Docker Compose hostnames.
# Override only if running services outside of Docker Compose.
MCP_SERVER_URL=http://mcp-server:8080/sse
REGISTRY_URL=http://registry:9000

VENUE_URL=http://venue-agent:8001
PRICING_URL=http://pricing-agent:8002
SPONSOR_URL=http://sponsor-agent:8003
SPEAKER_URL=http://speaker-agent:8004
EXHIBITOR_URL=http://exhibitor-agent:8005
COMMUNITY_URL=http://community-agent:8006
EVENTOPS_URL=http://eventops-agent:8000
